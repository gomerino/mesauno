NEXT_PUBLIC_SUPABASE_URL=https://tu-proyecto.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=tu_anon_key

# URL pública del sitio (obligatoria para que invitaciones/activación NO apunten a localhost).
# Prioridad: SITE_URL (solo servidor) o NEXT_PUBLIC_SITE_URL (también en el navegador).
# En Vercel suele bastar VERCEL_URL si no usas dominio propio aún.
# SITE_URL=https://tu-dominio.com
# NEXT_PUBLIC_SITE_URL=https://tu-dominio.com
#
# En Supabase: Authentication → URL Configuration → "Site URL" debe ser ese mismo origen (no localhost)
# y en "Redirect URLs" incluye https://tu-dominio.com/login (y http://localhost:3000/login solo en dev).

# Cuentas de administración de plataforma: solo /admin (crear eventos, invitar miembros a eventos).
# Esos emails NO pueden usar /panel (novios); se redirigen a /admin/eventos.
# Novios y gestores del evento usan /panel; no pongas su email aquí salvo que quieras que sean solo admin.
# ADMIN_EMAILS=admin@tudominio.com
# Opcional: un solo email con ADMIN_EMAIL=...
#
# Obligatorio para /api/admin/eventos: SUPABASE_SERVICE_ROLE_KEY (no la anon). Sin ella: error al invitar usuarios.
# SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# Invitación — música (al menos una variable; si no, no se muestra el bloque).
# Opción A: un solo enlace (detecta Spotify o Apple Music automáticamente).
# NEXT_PUBLIC_EVENT_PLAYLIST_URL=https://music.apple.com/cl/library/playlist/p.oOzA3WehERVgR8?l=en
# Opción B: enlaces explícitos (puedes usar ambos a la vez).
# NEXT_PUBLIC_SPOTIFY_PLAYLIST_URL=https://open.spotify.com/playlist/xxxxxxxx
# NEXT_PUBLIC_APPLE_MUSIC_PLAYLIST_URL=https://music.apple.com/cl/library/playlist/p.oOzA3WehERVgR8?l=en
# Reproductor embebido solo Spotify (152px); en móvil alarga la página.
# NEXT_PUBLIC_SPOTIFY_EMBED=0
# Código IATA ficticio “origen” en el boarding pass (3 letras).
# NEXT_PUBLIC_BOARDING_ORIGIN_CODE=SCL

# Dirección del evento para el QR (Google Maps) y texto del lugar en el boarding pass.
# Si está definida, tiene prioridad sobre el campo destino de cada invitado.
# NEXT_PUBLIC_EVENT_ADDRESS=Av. Ejemplo 123, Comuna, Chile

# Resend — envío de invitaciones por correo (https://resend.com)
# RESEND_API_KEY=re_CQn399Pb_MfSuaeHcGZjsdYNYK9sFCLqf
# RESEND_FROM_EMAIL=gonzalo.a.merino@gmail.com
#
# Recordatorios automáticos (Vercel Cron u otro): GET o POST /api/cron/reminders con cabecera
# Authorization: Bearer <mismo valor>. Requiere SUPABASE_SERVICE_ROLE_KEY y migración migration_recordatorios.sql.
# CRON_SECRET=genera_un_string_largo_aleatorio

# Secret service_role (Dashboard → Project Settings → API). Requerida para /api/rsvp (invitados sin login).
# No uses el texto de ejemplo; una clave inválida produce "Invalid API key".
# SUPABASE_SERVICE_ROLE_KEY=

# Spotify — música colaborativa en la invitación (Dashboard → Vincular playlist)
# SPOTIFY_CLIENT_ID=
# SPOTIFY_CLIENT_SECRET=
# SPOTIFY_REDIRECT_URI=https://tu-dominio.com/api/spotify/callback   (debe coincidir con el panel de Spotify)
# SPOTIFY_OAUTH_STATE_SECRET=...   (opcional; por defecto usa SPOTIFY_CLIENT_SECRET)
# SUPABASE_SERVICE_ROLE_KEY obligatoria para guardar refresh_token y leer credenciales desde el servidor.

# Mercado Pago — membresía Mesa Uno (Checkout Pro)
# MP_ACCESS_TOKEN=APP_USR-...   (credencial de producción o test desde Tu integración)
# MP_PUBLIC_KEY=APP_USR-...     (clave pública; en cliente usa NEXT_PUBLIC_MP_PUBLIC_KEY o la misma vía API)
# NEXT_PUBLIC_MP_PUBLIC_KEY=APP_USR-...  (recomendada si usas SDK JS en el navegador)
# MP_WEBHOOK_SECRET=...         (firma secreta de webhooks en Tu integración → Webhooks)
# MP_MEMBERSHIP_UNIT_PRICE_CLP=19990   (opcional; entero CLP)
# MP_USE_SANDBOX=1              (opcional; usa sandbox_init_point en dev / credenciales de prueba)
#
# Webhook URL pública: https://TU_DOMINIO/api/webhooks/mercadopago
# (Mercado Pago debe poder alcanzarla por HTTPS; en local usa ngrok o similar.)

# Apple Wallet — rutas a PEM (Pass Type ID + clave + WWDR)
# WALLET_PASS_TYPE_IDENTIFIER=pass.com.tudominio.boda
# WALLET_TEAM_IDENTIFIER=XXXXXXXXXX
# WALLET_SIGNER_CERT_PATH=./certs/signer.pem
# WALLET_SIGNER_KEY_PATH=./certs/signer.key
# WALLET_WWDR_CERT_PATH=./certs/wwdr.pem
