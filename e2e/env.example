# Copiá a `e2e/.env` o exportá en la shell antes de `npm run test:e2e`.
# `dotenv` también intenta cargar `.env.local` en la raíz (ver playwright.config.ts).

# URL de la app (Next en dev o preview desplegado)
PLAYWRIGHT_BASE_URL=http://127.0.0.1:3000

# Usuario con contraseña conocida (panel novios). Obligatorio para login, viaje, invitados e invitación.
# Creá el usuario en tu proyecto Supabase (confirmación de correo según tu entorno).
E2E_USER_EMAIL=
E2E_USER_PASSWORD=

# En CI, el servidor ya está arriba:
# PLAYWRIGHT_SKIP_WEBSERVER=1
